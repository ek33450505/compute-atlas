# Neon Postgres pooled connection string (Project > Connect > Pooled connection).
DATABASE_URL=

# Bearer token required by the admin-only write API (Phase 2+). Generate a
# long random value and keep it out of version control. Also gates the
# admin UI's `admin_session` cookie (proxy.ts / lib/admin-session.ts).
API_ADMIN_TOKEN=

# Optional: salt for hashing submitter IPs used only for public-contribution rate limiting.
# Falls back to a built-in default if unset. Set a random value in production for stronger hashing.
CONTRIBUTE_IP_SALT=
